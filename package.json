{
  "name": "personal-web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "NODE_OPTIONS='--inspect' next dev",
    "build": "bun run registry:build && next build && bun run generate:routes",
    "start": "next start",
    "generate:routes": "bun run scripts/generate-routes.ts",
    "registry:build": "bun run scripts/build-registry.ts",
    "lint": "biome check",
    "biome:lint": "biome check",
    "biome:format": "biome format --write",
    "db:generate": "bun run db:generate:auth && bun run db:generate:migrations",
    "db:generate:auth": "bunx @better-auth/cli generate --config ./src/lib/auth/index.ts --output ./src/lib/db/schema/auth.ts -y",
    "db:generate:migrations": "drizzle-kit generate",
    "db:migrate": "bun src/lib/db/migrate.ts",
    "db:drop": "drizzle-kit drop",
    "db:pull": "drizzle-kit introspect",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "db:check": "drizzle-kit check",
    "preinstall": "npx only-allow bun",
    "postinstall": "bun db:migrate"
  },
  "dependencies": {
